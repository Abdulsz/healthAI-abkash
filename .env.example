# Copy to .env.local and fill in. The app RUNS WITHOUT ANY of these (mock mode).

# --- LLM (xAI / Grok — the sponsor). OpenAI-compatible. ---
# Get a key at https://console.x.ai
LLM_API_KEY=
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-3

# To use Groq instead (NOT the xAI sponsor, but fast):
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile

# To route through Vercel AI Gateway (Vercel track), point LLM_BASE_URL there.

# --- Insurance Navigator adapters ---
# mock (default) or grok
INS_NAV_INSURANCE_ADAPTER=mock
# mock only for now
INS_NAV_PROVIDER_SEARCH_ADAPTER=mock
INS_NAV_PROVIDER_QUOTE_ADAPTER=mock
INS_NAV_BOOKING_ADAPTER=mock
# pipeline (default) or vercel
INS_NAV_AGENT_LOOP=pipeline

# xAI key used by realtime Grok voice adapters
XAI_API_KEY=
INS_NAV_GROK_VOICE_MODEL=grok-voice-think-fast-1.1
INS_NAV_GROK_VOICE_NAME=sal
# Fixed destination for provider pricing stage call
INS_NAV_PROVIDER_PRICING_CALL_TO=+17043885498

# --- Telephony bridge (Twilio <-> xAI realtime) ---
TELEPHONY_BRIDGE_PORT=8788
# Public HTTPS URL for your running bridge (e.g. https://xxxx.ngrok-free.app)
TELEPHONY_PUBLIC_BASE_URL=
# Where the Next.js backend can reach the bridge service
TELEPHONY_BRIDGE_INTERNAL_URL=http://localhost:8788
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional custom call-agent instructions for live calls
TELEPHONY_AGENT_INSTRUCTIONS=
